{
  "name": "@my-caffe/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/handler.js",
  "scripts": {
    "activate:customer": "tsx src/scripts/activateCustomer.ts",
    "build": "tsc -p tsconfig.json && node scripts/write-lambda-package-json.mjs",
    "dev": "tsx src/localServer.ts",
    "find:customer": "tsx src/scripts/findCustomer.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@my-caffe/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "vitest": "^4.1.9"
  }
}
