{
  "name": "@my-caffe/infra-cdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "deploy": "pnpm preflight:dev && pnpm synth && cdk deploy",
    "deploy:ci": "pnpm preflight:dev && pnpm synth && cdk deploy --require-approval never",
    "diff": "pnpm synth && cdk diff",
    "lint": "tsc -p tsconfig.json --noEmit",
    "preflight:dev": "tsx scripts/validateDevDeployEnv.ts",
    "smoke:dev": "tsx scripts/smokeDevDeployment.ts",
    "synth": "pnpm --filter @my-caffe/api build && pnpm --filter @my-caffe/customer-web build && cdk synth",
    "test": "echo \"No infra tests yet\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "aws-cdk": "^2.1128.1",
    "tsx": "^4.19.2"
  }
}
