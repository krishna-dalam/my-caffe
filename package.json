{
  "name": "my-caffe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @my-caffe/api dev",
    "dev:customer": "pnpm --filter @my-caffe/customer-web dev",
    "infra:synth": "pnpm --filter @my-caffe/infra-cdk synth",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
