{
  "name": "my-caffe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "activate:customer": "pnpm --filter @my-caffe/api run activate:customer",
    "build": "pnpm --filter @my-caffe/shared build && pnpm -r --filter \"!@my-caffe/shared\" build",
    "dev:admin": "pnpm --filter @my-caffe/admin-web run dev",
    "dev:api": "pnpm --filter @my-caffe/api run dev",
    "dev:customer": "pnpm --filter @my-caffe/customer-web run dev",
    "find:customer": "pnpm --filter @my-caffe/api run find:customer",
    "seed:dev-cafe": "pnpm --filter @my-caffe/api run seed:dev-cafe",
    "infra:deploy": "pnpm --filter @my-caffe/infra-cdk run deploy",
    "infra:deploy:ci": "pnpm --filter @my-caffe/infra-cdk run deploy:ci",
    "infra:diff": "pnpm --filter @my-caffe/infra-cdk run diff",
    "infra:preflight:dev": "pnpm --filter @my-caffe/infra-cdk run preflight:dev",
    "infra:print:github-oidc-policies": "pnpm --filter @my-caffe/infra-cdk run print:github-oidc-policies",
    "infra:synth": "pnpm --filter @my-caffe/infra-cdk run synth",
    "smoke:dev": "pnpm --filter @my-caffe/infra-cdk run smoke:dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
